generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilizador {
  id         Int            @id @default(autoincrement())
  password   String         @default("123456")
  role       Role           @default(RESPONSAVEL_STOCK)
  username   String         @unique
  ativo      Boolean        @default(true)
  avaliacoes Avaliacao[]
  pedidos    PedidoCompra[]
}

model Produto {
  id                       Int                 @id @default(autoincrement())
  nome                     String
  criadoEm                 DateTime            @default(now())
  stock                    Float               @default(0)
  stockMinimo              Float               @default(0)
  categoria                String?
  descricao                String?
  preco                    Float               @default(0)
  linhasEncomenda          LinhaEncomenda[]
  linhasPedido             LinhaPedidoCompra[]
  fornecedores             Fornecedor[]        @relation("FornecedorToProduto")
  precosFornecedores       ProdutoFornecedor[]
  fornecedorPreferencialId Int?
  fornecedorPreferencial   Fornecedor?         @relation("Preferencial", fields: [fornecedorPreferencialId], references: [id])
}

model Fornecedor {
  id                    Int                 @id @default(autoincrement())
  nome                  String
  nif                   String              @unique
  contacto              String
  categoria             String
  criadoEm              DateTime            @default(now())
  email                 String              @unique
  estado                Boolean             @default(true)
  observacoes           String?
  custoTransporte       Float?
  diasEntrega           String?
  metodoPagamento       String?
  prazoMedioEntrega     Int?
  valorMinimoEncomenda  Float?
  avaliacoes            Avaliacao[]
  encomendas            Encomenda[]
  linhasPedido          LinhaPedidoCompra[]
  produtos              Produto[]           @relation("FornecedorToProduto")
  produtosPreferenciais Produto[]           @relation("Preferencial")
  precosProdutos        ProdutoFornecedor[]
}

model Avaliacao {
  id           Int        @id @default(autoincrement())
  fornecedorId Int
  comentario   String?
  dataCriacao  DateTime   @default(now())
  comunicacao  Int        @default(3)
  conformidade Int        @default(3)
  pontualidade Int        @default(3)
  preco        Int        @default(3)
  qualidade    Int        @default(3)
  utilizadorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id])

  @@unique([fornecedorId, utilizadorId])
}

model PedidoCompra {
  id                 Int                 @id @default(autoincrement())
  estado             String              @default("PENDENTE")
  atualizadoEm       DateTime            @updatedAt
  criadoEm           DateTime            @default(now())
  criadoPorId        Int?
  valorTotalEstimado Float               @default(0)
  prioridade         PrioridadePedido    @default(NORMAL)
  tipo               TipoPedido          @default(MANUAL)
  observacoes        String?
  encomendas         Encomenda[]
  linhas             LinhaPedidoCompra[]
  criadoPor          Utilizador?         @relation(fields: [criadoPorId], references: [id])
}

model LinhaPedidoCompra {
  id             Int          @id @default(autoincrement())
  pedidoCompraId Int
  produtoId      Int
  quantidade     Float
  precoUnitario  Float
  valorTotal     Float
  fornecedorId   Int?
  fornecedor     Fornecedor?  @relation(fields: [fornecedorId], references: [id])
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id])
  produto        Produto      @relation(fields: [produtoId], references: [id])
}

model Encomenda {
  id                  Int              @id @default(autoincrement())
  codigoFormatado     String           @unique
  estado              EstadoEncomenda  @default(EMITIDA)
  dataEmissao         DateTime         @default(now())
  dataEntregaPrevista DateTime?
  dataEntregaReal     DateTime?
  valorTotal          Float            @default(0)
  observacoes         String?
  fornecedorId        Int
  pedidoCompraId      Int
  fornecedor          Fornecedor       @relation(fields: [fornecedorId], references: [id])
  pedidoCompra        PedidoCompra     @relation(fields: [pedidoCompraId], references: [id])
  linhas              LinhaEncomenda[]
}

model LinhaEncomenda {
  id                 Int       @id @default(autoincrement())
  encomendaId        Int
  produtoId          Int
  quantidade         Float
  precoUnitario      Float
  valorTotal         Float
  quantidadeRecebida Float     @default(0)
  encomenda          Encomenda @relation(fields: [encomendaId], references: [id])
  produto            Produto   @relation(fields: [produtoId], references: [id])
}

enum Role {
  ADMINISTRADOR
  RESPONSAVEL_STOCK
  RESPONSAVEL_FINANCEIRO
}

enum TipoPedido {
  MANUAL
  AUTOMATICO
}

enum PrioridadePedido {
  NORMAL
  ALTA
  URGENTE
}

model ProdutoFornecedor {
  id           Int        @id @default(autoincrement())
  produtoId    Int
  fornecedorId Int
  preco        Float
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  produto      Produto    @relation(fields: [produtoId], references: [id])

  @@unique([produtoId, fornecedorId])
}

enum EstadoEncomenda {
  EMITIDA
  ENVIADA
  ENTREGUE
  CANCELADA
  ENTREGUE_PARCIAL
}
