generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMINISTRADOR
  RESPONSAVEL_STOCK
  RESPONSAVEL_FINANCEIRO
}

model Utilizador {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String  @default("123456") // Para simplicidade neste estágio
  role     Role    @default(RESPONSAVEL_STOCK)

  pedidos PedidoCompra[]
}

model Produto {
  id          Int          @id @default(autoincrement())
  nome        String
  stock       Float        @default(0)
  stockMinimo Float        @default(0) // US1.4 - Definir Stock Mínimo
  preco       Float        @default(0)
  categoria   String?
  descricao   String?
  criadoEm    DateTime     @default(now())

  linhasPedido LinhaPedidoCompra[]
  fornecedores Fornecedor[] // US1.9 - Associar Fornecedor a Produto
}

model Fornecedor {
  id         Int            @id @default(autoincrement())
  nome       String
  nif        String         @unique
  contacto   String
  email      String         @unique
  estado     Boolean        @default(true)
  categoria  String
  observacoes String? @db.Text
  criadoEm   DateTime       @default(now())
  
  produtos   Produto[]      // US1.9 - Associar a Produto
  avaliacoes Avaliacao[]    // US1.8 - Avaliar Fornecedor
}

model Avaliacao {
  id           Int        @id @default(autoincrement())
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  
  qualidade    Int        @default(3) // 1-5
  pontualidade Int        @default(3) // 1-5
  comunicacao  Int        @default(3) // 1-5
  preco        Int        @default(3) // 1-5
  conformidade Int        @default(3) // 1-5
  comentario   String?
  dataCriacao  DateTime   @default(now())
}

enum PrioridadePedido {
  NORMAL
  ALTA
  URGENTE
}

model PedidoCompra {
  id                  Int                 @id @default(autoincrement())
  estado              String              @default("PENDENTE")
  prioridade          PrioridadePedido    @default(NORMAL)
  valorTotalEstimado  Float               @default(0)
  
  criadoPorId         Int?
  criadoPor           Utilizador?         @relation(fields: [criadoPorId], references: [id])
  
  criadoEm            DateTime            @default(now())
  atualizadoEm        DateTime            @updatedAt

  linhas              LinhaPedidoCompra[]
}

model LinhaPedidoCompra {
  id             Int          @id @default(autoincrement())
  pedidoCompraId Int
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id])
  
  produtoId      Int
  produto        Produto      @relation(fields: [produtoId], references: [id])
  
  quantidade     Float
  precoUnitario  Float
  valorTotal     Float
}
