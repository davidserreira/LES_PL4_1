generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMINISTRADOR
  RESPONSAVEL_STOCK
  RESPONSAVEL_FINANCEIRO
}

model Utilizador {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String @default("123456") // Para simplicidade neste estágio
  role     Role   @default(RESPONSAVEL_STOCK)
  ativo    Boolean @default(true) // US: Ativar/Inativar utilizador

  pedidos PedidoCompra[]
  avaliacoes Avaliacao[]
}

model Produto {
  id          Int      @id @default(autoincrement())
  nome        String
  stock       Float    @default(0)
  stockMinimo Float    @default(0) // US1.4 - Definir Stock Mínimo
  preco       Float    @default(0)
  categoria   String?
  descricao   String?
  criadoEm    DateTime @default(now())

  linhasPedido LinhaPedidoCompra[]
  fornecedores Fornecedor[] // US1.9 - Associar Fornecedor a Produto
  linhasEncomenda LinhaEncomenda[]
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  nome        String
  nif         String   @unique
  contacto    String
  email       String   @unique
  estado      Boolean  @default(true)
  categoria   String
  observacoes String?  @db.Text
  criadoEm    DateTime @default(now())

  // Condições Comerciais / Compra
  valorMinimoEncomenda Float?
  prazoMedioEntrega    Int?
  custoTransporte      Float?
  metodoPagamento      String?
  diasEntrega          String?

  produtos   Produto[] // US1.9 - Associar a Produto
  avaliacoes Avaliacao[] // US1.8 - Avaliar Fornecedor
  linhasPedido LinhaPedidoCompra[]
  encomendas Encomenda[]
}

model Avaliacao {
  id           Int        @id @default(autoincrement())
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  utilizadorId Int
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id])

  qualidade    Int      @default(3) // 1-5
  pontualidade Int      @default(3) // 1-5
  comunicacao  Int      @default(3) // 1-5
  preco        Int      @default(3) // 1-5
  conformidade Int      @default(3) // 1-5
  comentario   String?
  dataCriacao  DateTime @default(now())

  @@unique([fornecedorId, utilizadorId])
}

enum TipoPedido {
  MANUAL
  AUTOMATICO
}

enum PrioridadePedido {
  NORMAL
  ALTA
  URGENTE
}

model PedidoCompra {
  id                 Int              @id @default(autoincrement())
  estado             String           @default("PENDENTE")
  prioridade         PrioridadePedido @default(NORMAL)
  tipo               TipoPedido       @default(MANUAL)
  valorTotalEstimado Float            @default(0)
  observacoes        String?          @db.Text

  criadoPorId Int?
  criadoPor   Utilizador? @relation(fields: [criadoPorId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  linhas LinhaPedidoCompra[]
  encomendas Encomenda[]
}

model LinhaPedidoCompra {
  id             Int          @id @default(autoincrement())
  pedidoCompraId Int
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id])

  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id])

  fornecedorId  Int?
  fornecedor    Fornecedor? @relation(fields: [fornecedorId], references: [id])

  quantidade    Float
  precoUnitario Float
  valorTotal    Float
}

// ─── Encomendas ───────────────────────────────────────────────────────────────

enum EstadoEncomenda {
  EMITIDA
  ENVIADA
  ENTREGUE
  CANCELADA
}

model Encomenda {
  id                  Int             @id @default(autoincrement())
  codigoFormatado     String          @unique
  estado              EstadoEncomenda @default(EMITIDA)
  dataEmissao         DateTime        @default(now())
  dataEntregaPrevista DateTime?
  dataEntregaReal     DateTime?
  valorTotal          Float           @default(0)
  observacoes         String?         @db.Text

  fornecedorId        Int
  fornecedor          Fornecedor      @relation(fields: [fornecedorId], references: [id])

  pedidoCompraId      Int
  pedidoCompra        PedidoCompra    @relation(fields: [pedidoCompraId], references: [id])

  linhas              LinhaEncomenda[]
}

model LinhaEncomenda {
  id            Int       @id @default(autoincrement())
  encomendaId   Int
  encomenda     Encomenda @relation(fields: [encomendaId], references: [id])

  produtoId     Int
  produto       Produto   @relation(fields: [produtoId], references: [id])

  quantidade    Float
  precoUnitario Float
  valorTotal    Float
}
