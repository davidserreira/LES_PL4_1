generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilizador {
  id    Int     @id @default(autoincrement())
  email String  @unique
  nome  String?

  pedidos PedidoCompra[]
}

model Produto {
  id          Int          @id @default(autoincrement())
  nome        String
  stock       Float        @default(0)
  stockMinimo Float        @default(0) // US1.4 - Definir Stock Mínimo
  preco       Float        @default(0)
  categoria   String?
  descricao   String?
  criadoEm    DateTime     @default(now())

  itensPedido  ItemPedido[]
  fornecedores Fornecedor[] // US1.9 - Associar Fornecedor a Produto
}

model Fornecedor {
  id         Int            @id @default(autoincrement())
  nome       String
  nif        String?        @unique
  contacto   String?
  
  pedidos    PedidoCompra[]
  produtos   Produto[]      // US1.9 - Associar a Produto
  avaliacoes Avaliacao[]    // US1.8 - Avaliar Fornecedor
}

model Avaliacao {
  id           Int        @id @default(autoincrement())
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  
  pontuacao    Float      // Ex: 0-10 ou 1-5
  comentario   String?
  dataCriacao  DateTime   @default(now())
}

model PedidoCompra {
  id             Int        @id @default(autoincrement())
  dataPedido     DateTime   @default(now())
  estado         String     @default("PENDENTE")
  
  responsavelId  Int
  responsavel    Utilizador @relation(fields: [responsavelId], references: [id])
  
  fornecedorId   Int
  fornecedor     Fornecedor @relation(fields: [fornecedorId], references: [id])

  itens          ItemPedido[]
}

model ItemPedido {
  id             Int          @id @default(autoincrement())
  pedidoId       Int
  pedido         PedidoCompra @relation(fields: [pedidoId], references: [id])
  
  produtoId      Int
  produto        Produto      @relation(fields: [produtoId], references: [id])
  
  quantidade     Float
}
