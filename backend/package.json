{
    "name": "backend",
    "version": "1.0.0",
    "description": "API REST Node.js com Express",
    "main": "src/server.ts",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "npx prisma generate && tsc",
        "build:render": "npx prisma generate && npx prisma db push --force-reset && npx prisma db seed && tsc"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "cors": "^2.8.5",
        "express": "^4.18.3",
        "pg": "^8.11.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.24",
        "@types/pg": "^8.11.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "dotenv": "^17.3.1",
        "prisma": "^7.4.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
